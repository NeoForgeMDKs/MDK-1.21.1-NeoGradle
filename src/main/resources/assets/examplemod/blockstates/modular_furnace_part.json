{
  "multipart": [
    { "when": { "facing": "north" }, "apply": { "y": 0 } },
    { "when": { "facing": "east" },  "apply": { "y": 90 } },
    { "when": { "facing": "south" }, "apply": { "y": 180 } },
    { "when": { "facing": "west" },  "apply": { "y": 270 } },

    { "when": { "part_x": 0, "part_y": 2, "part_z": 2 }, "apply": { "model": "examplemod:block/furnace_wall_top_left" } },
    { "when": { "part_x": 1, "part_y": 2, "part_z": 2 }, "apply": { "model": "examplemod:block/furnace_wall_top_center" } },
    { "when": { "part_x": 2, "part_y": 2, "part_z": 2 }, "apply": { "model": "examplemod:block/furnace_wall_top_right" } },
    { "when": { "part_x": 0, "part_y": 1, "part_z": 2 }, "apply": { "model": "examplemod:block/furnace_wall_mid_left" } },
    { "when": { "part_x": 1, "part_y": 1, "part_z": 2 }, "apply": { "model": "examplemod:block/furnace_wall_mid_center" } },
    { "when": { "part_x": 2, "part_y": 1, "part_z": 2 }, "apply": { "model": "examplemod:block/furnace_wall_mid_right" } },
    { "when": { "part_x": 0, "part_y": 0, "part_z": 2 }, "apply": { "model": "examplemod:block/furnace_wall_bot_left" } },
    { "when": { "part_x": 1, "part_y": 0, "part_z": 2 }, "apply": { "model": "examplemod:block/furnace_wall_bot_center" } },
    { "when": { "part_x": 2, "part_y": 0, "part_z": 2 }, "apply": { "model": "examplemod:block/furnace_wall_bot_right" } },

    { "when": { "part_x": 0, "part_y": 0, "part_z": 1 }, "apply": { "model": "examplemod:block/furnace_bottom_casing" } },
    { "when": { "part_x": 1, "part_y": 0, "part_z": 1 }, "apply": { "model": "examplemod:block/furnace_bottom_casing" } },
    { "when": { "part_x": 2, "part_y": 0, "part_z": 1 }, "apply": { "model": "examplemod:block/furnace_bottom_casing" } },
    { "when": { "part_x": 0, "part_y": 1, "part_z": 1 }, "apply": { "model": "examplemod:block/furnace_top_casing" } }, 
    { "when": { "part_x": 2, "part_y": 1, "part_z": 1 }, "apply": { "model": "examplemod:block/furnace_top_casing" } }, 
    { "when": { "part_x": 0, "part_y": 2, "part_z": 1 }, "apply": { "model": "examplemod:block/furnace_top_casing" } },
    { "when": { "part_x": 1, "part_y": 2, "part_z": 1 }, "apply": { "model": "examplemod:block/furnace_top_casing" } },
    { "when": { "part_x": 2, "part_y": 2, "part_z": 1 }, "apply": { "model": "examplemod:block/furnace_top_casing" } },

    { "when": { "part_x": 0, "part_y": 0, "part_z": 0 }, "apply": { "model": "examplemod:block/furnace_bottom_casing" } },
    { "when": { "part_x": 1, "part_y": 0, "part_z": 0 }, "apply": { "model": "examplemod:block/furnace_bottom_casing" } },
    { "when": { "part_x": 2, "part_y": 0, "part_z": 0 }, "apply": { "model": "examplemod:block/furnace_bottom_casing" } },
    { "when": { "part_x": 0, "part_y": 1, "part_z": 0 }, "apply": { "model": "examplemod:block/furnace_top_casing" } },
    { "when": { "part_x": 1, "part_y": 1, "part_z": 0 }, "apply": { "model": "examplemod:block/furnace_top_casing" } },
    { "when": { "part_x": 2, "part_y": 1, "part_z": 0 }, "apply": { "model": "examplemod:block/furnace_top_casing" } },
    { "when": { "part_x": 0, "part_y": 2, "part_z": 0 }, "apply": { "model": "examplemod:block/furnace_top_casing" } },
    { "when": { "part_x": 1, "part_y": 2, "part_z": 0 }, "apply": { "model": "examplemod:block/furnace_top_casing" } },
    { "when": { "part_x": 2, "part_y": 2, "part_z": 0 }, "apply": { "model": "examplemod:block/furnace_top_casing" } }
  ]
}